VITE_APP_ID=web3-wallet-chat
VITE_STUN_SERVERS=stun:stun.cloudflare.com:3478,stun:stun.l.google.com:19302

# Leave empty to use trystero built-in public relays.
# Only fill this if you want to force your own relay URLs, comma-separated.
# Example:
# VITE_RELAY_URLS=wss://relay1.example.com,wss://relay2.example.com
VITE_RELAY_URLS=

# Fill this after your TURN server is online.
# Example:
# VITE_TURN_URLS=turn:YOUR_SERVER_IP:3478?transport=udp,turn:YOUR_SERVER_IP:3478?transport=tcp
VITE_TURN_URLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
VITE_PREFER_TURN=false
VITE_TURN_ONLY_TIMEOUT_MS=6000
VITE_HANDSHAKE_TTL_MS=86400000
VITE_INVITE_TTL_MS=43200000
VITE_ROOM_HISTORY_LIMIT=200
VITE_MAX_MESSAGE_LENGTH=1000
VITE_MESSAGE_FRESHNESS_MS=600000
